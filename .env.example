# ============================================================
# Smart Washer Notification System - 環境變數範本
# Environment Variables Template
# ============================================================
# 複製此檔案為 .env 並填入實際值
# Copy this file to .env and fill in your actual values
# ============================================================

# --- AWS 基本設定 / AWS General ---
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=your-aws-account-id

# --- SNS Topic ARNs ---
# 用於 Lambda 函式中的通知發送
# Used by Lambda functions to publish notifications
SNS_TOPIC_ARN_RESERVED_NOTIFICATION=arn:aws:sns:us-east-1:<ACCOUNT_ID>:team06-SendReservedUserNotification
SNS_TOPIC_ARN_LEFT_TIME_ALERT=arn:aws:sns:us-east-1:<ACCOUNT_ID>:team06-SendUserLeftTimeAlert
SNS_TOPIC_ARN_REKOGNITION_ALARM=arn:aws:sns:us-east-1:<ACCOUNT_ID>:team06-RekognitionAlarmNotify

# --- SNS 通知信箱 / Notification Email ---
# SNS subscription 的目標信箱（部署後需至信箱確認訂閱）
# Target email for SNS subscriptions (confirm subscription after deploy)
NOTIFICATION_EMAIL=your-email@example.com

# --- Lambda ARNs（用於 EventBridge Scheduler） ---
# team06_ActivateEvent 需要呼叫 team06_CheckAndReleaseWasher
TARGET_LAMBDA_ARN_CHECK_RELEASE=arn:aws:lambda:us-east-1:<ACCOUNT_ID>:function:team06_CheckAndReleaseWasher
# team06_EndWashSession 需要呼叫 team06_DelayedShadowUpdate
TARGET_LAMBDA_ARN_DELAYED_SHADOW=arn:aws:lambda:us-east-1:<ACCOUNT_ID>:function:team06_DelayedShadowUpdate

# --- EventBridge Scheduler IAM Role ---
SCHEDULER_ROLE_ARN=arn:aws:iam::<ACCOUNT_ID>:role/team06-scheduler-role

# --- IoT Core ---
IOT_ENDPOINT=a2l2r8z087kz73-ats.iot.us-east-1.amazonaws.com
IOT_THING_NAME=team06_IoT
IOT_MQTT_TOPIC=device/camera/image

# --- S3 Buckets ---
S3_BUCKET_IMAGES=team06-times-image-temp
S3_BUCKET_WEBSITE=team06website-temp

# --- Cognito ---
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# --- API Gateway ---
API_GATEWAY_ID=xxxxxxxxxx
API_GATEWAY_STAGE=prod

# --- DynamoDB Tables ---
DYNAMODB_TABLE_WASHER_STATUS=team06-WasherStatus
DYNAMODB_TABLE_USER_INFO=team06-UserInfo

# --- IoT 裝置端設定（Raspberry Pi 上使用）---
# IoT Device Configuration (used on Raspberry Pi)
IOT_CERT_ROOT_CA=config/AmazonRootCA1_RSA.pem
IOT_CERT_CERTIFICATE=config/certificate.pem
IOT_CERT_PRIVATE_KEY=config/private.pem.key
